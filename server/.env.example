# ---- SOLID backend configuration ----
# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Port the server listens on
PORT=5511

# Comma-separated list of allowed origins for the API (CORS).
# Use "*" while testing. In production set it to the live domain, e.g. https://solidlights.in
CORS_ORIGIN=*

# Admin token — required to view/manage enquiries at /admin.
# Use a long random string. Generate one with:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_TOKEN=change-me-to-a-long-random-string

# Business WhatsApp number (international format, no +). Used in notification emails.
WHATSAPP_NUMBER=919860116122

# ---- Email notifications (optional) ----
# Leave SMTP_* blank to disable email. Enquiries are still saved to the JSON store.
# Gmail example: create an "App Password" (Google Account > Security > App passwords).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Where notification emails are sent (defaults to SMTP_USER if blank)
NOTIFY_TO=solidstateindia@gmail.com
# "From" shown on notification emails (defaults to SMTP_USER if blank)
NOTIFY_FROM=
